%% 
 % Use the alternative versions of `less than or equal to' and
 % `greater     than or equal to.'
 %%
 \renewcommand{\le}{\leqslant} \renewcommand{\ge}{\geqslant} 
%%
 % Define a list-type environment `conditions' whose 
 % \item's get labeled using the equation counter. Used 
 % for listing conditions of a theorem, etc
 %%
 \def\adoptcounter#1{\@nmbrlisttrue\def\@listctr{#1}} % Same as
 % \usecounter but does not reset the counter to zero                          
 \newenvironment{conditions}%
 {\begin{list}%
       {\normalfont(\theequation)}%
       {\adoptcounter{equation}\settowidth{\labelwidth}{(8)}%
                                   \settowidth{\labelsep}{8}%
                                \setlength{\itemindent}{0pt}%
                          \setlength{\leftmargin}{\labelsep}%
                      \addtolength{\leftmargin}{\labelwidth}%
                     \addtolength{\leftmargin}{-\itemindent}}}
 {\end{list}}
%% 
 % Suppress subsection entries in Table of Contents
 %%
 \setcounter{tocdepth}{1}
%% 
 % Styles for referencing
 %%
 \newcommand{\eqrefs}[2]{{\normalfont\ref{#1}(\ref{#2})}} 
 \newcommand{\lab}[1]{\label{#1}}      % These three are modified
 \newcommand{\mathlab}[1]{\label{#1}}  % for drafting purposes if
 \newcommand{\figlab}[1]{\label{#1}}   % show_labels package is loaded.
